@startuml

class User {
  - id: int
  - name: string
  - email: string
  - passwordHash: string
  - createdAt: datetime
  + getName(): string
}

class UserManager{
  + register(name, email, password): User
  + login(email, password): User
  + logout(user): void
}

class SearchManager{
  + searchThreadTitle(keyword): Thread[]
  + searchThreadUser(userName): Thread[]
}

abstract class Post {
  - id: int
  - content: string
  - userId: int
  - createdAt: datetime
  + update(title, content): void
  + delete(user): void
  + addReaction(user, reaction): void
}

class Thread {
  - title: string
  + create(user, title, content): Thread
  + getResponses(limit=500): Response[]
}

class Response {
  - thread: Thread
  + create(user, threadId ,content): Response
}

class Admin {
  + updateUser(user): void
  + deleteUser(userId): void
  + updatePost(post, content): void
  + deletePost(post): void
}

class Reaction {
  - id: int
  - type: string
  - user: User
  - post: Post
  - createdAt: datetime
  + Reaction(user, post, type): Reaction
}

User ..> Post : 作成
Post --> Reaction : リアクション
Thread --|> Post
Response --|> Post
Admin --|> User
UserManager ..> User : 作成
@enduml